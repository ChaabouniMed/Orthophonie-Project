CREATE TABLE patientRecord (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    date_birth TEXT,
    contact_parent TEXT,
    school TEXT,
    class TEXT,
    creation_date TEXT
);

insertPatient:
INSERT INTO patientRecord(id, first_name, last_name, date_birth, contact_parent, school, class, creation_date)
VALUES ?;

getPatients:
SELECT * FROM patientRecord;